<!-- ─── TOAST NOTIFICATION ─── -->
<div id="toast" style="
  position:fixed; bottom:24px; right:24px;
  background:var(--card); border:1px solid var(--border2);
  border-radius:10px; padding:12px 18px;
  font-size:13px; color:var(--text);
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  transform:translateY(80px); opacity:0;
  transition:all 0.3s ease;
  z-index:1000;
  max-width:300px;
  display:flex; align-items:center; gap:10px;
">
  <span style="color:var(--leaf)">✓</span>
  <span id="toast-msg"></span>
</div>

<script>
// ─── NAVIGATION ───
function navigate(page) {
  document.querySelectorAll('.page-content').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  const titles = {
    dashboard: 'Dashboard', irrigation: 'Smart Irrigation', pest: 'Bio-Sentinel',
    harvest: 'Harvest Pro', fertilizer: 'Ferti-Sync VRT', carbon: 'Carbon Ledger',
    insurance: 'Auto-Insurance', market: 'Market Oracle'
  };
  document.getElementById('topbar-title').textContent = titles[page] || page;
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.textContent.trim().toLowerCase().includes(page.toLowerCase().split('-')[0].substring(0,4)) ||
        (page === 'dashboard' && n.textContent.includes('Dashboard')) ||
        (page === 'irrigation' && n.textContent.includes('Irrigation')) ||
        (page === 'pest' && n.textContent.includes('Bio')) ||
        (page === 'harvest' && n.textContent.includes('Harvest')) ||
        (page === 'fertilizer' && n.textContent.includes('Ferti')) ||
        (page === 'carbon' && n.textContent.includes('Carbon')) ||
        (page === 'insurance' && n.textContent.includes('Insurance')) ||
        (page === 'market' && n.textContent.includes('Market'))) {
      n.classList.add('active');
    }
  });
  if (window.innerWidth <= 900) {
    document.getElementById('sidebar').classList.remove('open');
  }
  window.scrollTo(0, 0);
  initCharts();
}

// ─── SIDEBAR TOGGLE ───
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ─── LAYER TOGGLE ───
function setLayer(el) {
  el.closest('.map-card').querySelectorAll('.map-layer-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

// ─── LIVE TIME ───
function updateTime() {
  const now = new Date();
  document.getElementById('live-time').textContent =
    now.toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit', second:'2-digit'}) + ' IST';
}
setInterval(updateTime, 1000); updateTime();

// ─── DATE SLIDER ───
const months = ['May\'24','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan\'25','Feb','Mar','Apr'];
function updateDate(val, id) {
  document.getElementById(id).textContent = ['May 2024','Jun 2024','Jul 2024','Aug 2024','Sep 2024','Oct 2024','Nov 2024','Dec 2024','Jan 2025','Feb 2025','Mar 2025','Apr 28, 2025'][parseInt(val)] || 'Apr 28, 2025';
}

// ─── HARVEST OFFSET ───
function updateHarvestOffset(val) {
  const v = parseInt(val);
  const quality = Math.max(80, 97 - Math.abs(v) * 1.5);
  const profit = v < 0 ? `+${Math.abs(v)*3}% market gain` : v > 0 ? `+${v*1}% quality` : 'On peak date';
  document.getElementById('harvest-offset-label').textContent =
    v === 0 ? 'On peak date · Quality 97%' :
    v < 0 ? `Apr ${12+v} · Quality ${quality.toFixed(0)}% · ${profit}` :
    `Apr ${12+v} · Quality ${quality.toFixed(0)}% · past peak`;
}

// ─── FERTILIZER COST ───
function updateFertCost(val) {
  const bags = Math.round(54 / 45 * 100) / 100;
  const saving = Math.round(bags * parseInt(val));
  document.getElementById('fert-savings').textContent =
    `Saves 54 kg urea → ₹${saving.toLocaleString('en-IN')} this season`;
}

// ─── TOAST ───
function showToast(msg) {
  const toast = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  toast.style.transform = 'translateY(0)';
  toast.style.opacity = '1';
  setTimeout(() => {
    toast.style.transform = 'translateY(80px)';
    toast.style.opacity = '0';
  }, 3000);
}

// ─── CHARTS ───
function initCharts() {
  // NDRE chart (pest page)
  const ndreEl = document.getElementById('ndre-chart');
  if (ndreEl) {
    const ndreVals = [0.42, 0.41, 0.38, 0.32, 0.28];
    ndreEl.innerHTML = '';
    ndreVals.forEach((v, i) => {
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      const h = Math.round(v * 190);
      bar.style.height = h + 'px';
      bar.style.background = i === 4 ? 'var(--red)' : i === 3 ? 'var(--amber)' : 'var(--leaf-dim)';
      ndreEl.appendChild(bar);
    });
  }

  // SOC chart (carbon page)
  const socEl = document.getElementById('soc-chart');
  if (socEl) {
    const socVals = [1.5, 1.7, 1.9, 2.1, 2.3, 2.5, 2.7];
    socEl.innerHTML = '';
    socVals.forEach((v, i) => {
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      const h = Math.round((v / 3.0) * 55);
      bar.style.height = h + 'px';
      bar.style.background = i >= 5 ? 'rgba(212,175,55,0.5)' : 'var(--gold)';
      bar.style.borderTop = i >= 5 ? '1px dashed var(--gold)' : 'none';
      socEl.appendChild(bar);
    });
  }

  // Rain chart (insurance page)
  const rainEl = document.getElementById('rain-chart');
  if (rainEl) {
    const rainVals = [0,2,0,5,8,3,0,0,6,4,2,0,3,1,0,0,0,2,0,1,0,3,0,0,0,1,2,0,0,1];
    rainEl.innerHTML = '';
    rainVals.forEach(v => {
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      bar.style.height = Math.max(2, v * 8) + 'px';
      bar.style.background = 'var(--sat)';
      rainEl.appendChild(bar);
    });
    // add trigger line overlay
    const trigger = document.createElement('div');
    trigger.style.cssText = 'position:absolute;bottom:16px;left:0;right:0;height:1px;border-top:1px dashed rgba(239,68,68,0.5);pointer-events:none';
    rainEl.style.position = 'relative';
    rainEl.appendChild(trigger);
  }

  // Mandi price chart
  const mandiEl = document.getElementById('mandi-chart');
  if (mandiEl) {
    const mandiVals = [2150, 2180, 2200, 2240, 2280, 2310, 2350];
    mandiEl.innerHTML = '';
    mandiVals.forEach((v, i) => {
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      const h = Math.round(((v - 2100) / 300) * 65);
      bar.style.height = h + 'px';
      bar.style.background = i === 6 ? 'var(--sat)' : 'var(--sat-dim)';
      mandiEl.appendChild(bar);
    });
  }
}

// ─── INIT ───
initCharts();
navigate('dashboard');
</script>
