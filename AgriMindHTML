<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgriMind-GEE — Digital Agronomist</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #0F1409;
  --bg2:       #161D0E;
  --bg3:       #1E2714;
  --card:      #222E16;
  --border:    #2E3D1E;
  --border2:   #3A4F28;
  --leaf:      #6FAE3C;
  --leaf2:     #8FCC58;
  --leaf-dim:  #3A5E1F;
  --sat:       #4A9EFF;
  --sat-dim:   #1A3D6A;
  --amber:     #F59E0B;
  --amber-dim: #5A3A00;
  --red:       #EF4444;
  --red-dim:   #4A1010;
  --gold:      #D4AF37;
  --gold-dim:  #4A3A08;
  --text:      #D8E8CC;
  --text2:     #8A9E78;
  --text3:     #5A6E48;
  --mono:      'JetBrains Mono', monospace;
  --display:   'Fraunces', serif;
  --body:      'DM Sans', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg2); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* ─── LAYOUT ─── */
.app { display: flex; min-height: 100vh; }

/* ─── SIDEBAR ─── */
.sidebar {
  width: 220px;
  min-height: 100vh;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0; bottom: 0;
  z-index: 100;
  transition: transform 0.3s ease;
}
.sidebar-logo {
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--border);
}
.logo-mark {
  display: flex; align-items: center; gap: 10px;
}
.logo-icon {
  width: 32px; height: 32px;
  background: var(--leaf);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.logo-text {
  font-family: var(--display);
  font-size: 17px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.3px;
}
.logo-sub { font-size: 10px; color: var(--text3); font-family: var(--mono); letter-spacing: 0.5px; margin-top: 2px; }

.sidebar-farm {
  padding: 12px 16px;
  margin: 12px;
  background: var(--bg3);
  border-radius: 8px;
  border: 1px solid var(--border);
}
.farm-label { font-size: 10px; color: var(--text3); font-family: var(--mono); letter-spacing: 0.5px; margin-bottom: 4px; }
.farm-name { font-size: 13px; font-weight: 500; color: var(--text); }
.farm-meta { font-size: 11px; color: var(--text2); margin-top: 2px; }

.nav-section-label {
  font-size: 9px;
  font-family: var(--mono);
  color: var(--text3);
  letter-spacing: 1.5px;
  padding: 16px 20px 6px;
}
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 20px;
  cursor: pointer;
  transition: all 0.15s;
  border-left: 2px solid transparent;
  font-size: 13px;
  color: var(--text2);
  position: relative;
}
.nav-item:hover { background: var(--bg3); color: var(--text); }
.nav-item.active {
  background: linear-gradient(90deg, rgba(111,174,60,0.12) 0%, transparent 100%);
  border-left-color: var(--leaf);
  color: var(--leaf2);
}
.nav-icon { font-size: 14px; width: 18px; text-align: center; }
.nav-badge {
  margin-left: auto;
  background: var(--red);
  color: #fff;
  font-size: 9px;
  font-family: var(--mono);
  padding: 1px 5px;
  border-radius: 10px;
}
.nav-badge.green { background: var(--leaf); color: var(--bg); }

.sidebar-footer {
  margin-top: auto;
  padding: 16px;
  border-top: 1px solid var(--border);
}
.sat-status {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; color: var(--text2);
}
.sat-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--leaf);
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ─── MAIN CONTENT ─── */
.main {
  margin-left: 220px;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ─── TOP BAR ─── */
.topbar {
  height: 52px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 16px;
  position: sticky; top: 0; z-index: 50;
}
.topbar-title {
  font-family: var(--display);
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
}
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 12px; }
.topbar-time {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text3);
}
.alert-bell {
  width: 32px; height: 32px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 14px;
  position: relative;
}
.alert-dot {
  position: absolute; top: 5px; right: 5px;
  width: 7px; height: 7px;
  background: var(--red);
  border-radius: 50%;
  border: 1px solid var(--bg2);
}

/* ─── SOIL RIBBON ─── */
.soil-ribbon {
  background: var(--bg3);
  border-bottom: 1px solid var(--border);
  padding: 8px 24px;
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  overflow-x: auto;
}
.ribbon-label { color: var(--text3); font-family: var(--mono); font-size: 10px; letter-spacing: 0.5px; margin-right: 4px; }
.soil-pill {
  padding: 4px 10px;
  border-radius: 20px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 500;
  white-space: nowrap;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.15s;
}
.soil-pill.ok    { background: rgba(111,174,60,0.12); border-color: var(--leaf-dim); color: var(--leaf2); }
.soil-pill.warn  { background: rgba(245,158,11,0.12); border-color: var(--amber-dim); color: var(--amber); }
.soil-pill.crit  { background: rgba(239,68,68,0.12);  border-color: var(--red-dim);   color: var(--red); }
.soil-pill:hover { filter: brightness(1.2); }

/* ─── PAGE CONTENT ─── */
.page-content {
  padding: 24px;
  flex: 1;
  display: none;
}
.page-content.active { display: block; }

/* ─── MODULE HEADER ─── */
.module-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  margin-bottom: 20px;
}
.module-title-group {}
.module-icon-title { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
.module-emoji { font-size: 20px; }
.module-title {
  font-family: var(--display);
  font-size: 22px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.5px;
}
.module-desc { font-size: 13px; color: var(--text2); }
.module-meta {
  display: flex; flex-direction: column; align-items: flex-end; gap: 4px;
}
.meta-tag {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
}
.refresh-btn {
  padding: 6px 12px;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 6px;
  color: var(--leaf2);
  font-size: 11px;
  font-family: var(--mono);
  cursor: pointer;
  transition: all 0.15s;
  display: flex; align-items: center; gap: 6px;
}
.refresh-btn:hover { background: var(--card); border-color: var(--leaf); }

/* ─── TWO-COLUMN LAYOUT ─── */
.module-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 16px;
  align-items: start;
}

/* ─── FAKE MAP ─── */
.map-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  min-height: 380px;
}
.map-inner {
  width: 100%;
  height: 380px;
  position: relative;
  overflow: hidden;
}
.map-bg {
  width: 100%; height: 100%;
  position: absolute;
}
.map-overlay-label {
  position: absolute;
  top: 12px; left: 12px;
  background: rgba(15,20,9,0.8);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 10px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text2);
  backdrop-filter: blur(4px);
}
.map-layers {
  position: absolute;
  bottom: 12px; left: 12px;
  display: flex; gap: 6px;
}
.map-layer-btn {
  padding: 5px 10px;
  background: rgba(15,20,9,0.85);
  border: 1px solid var(--border);
  border-radius: 20px;
  font-size: 10px;
  font-family: var(--mono);
  color: var(--text2);
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: all 0.15s;
}
.map-layer-btn.active { background: rgba(111,174,60,0.25); border-color: var(--leaf); color: var(--leaf2); }
.map-layer-btn:hover { color: var(--text); border-color: var(--border2); }
.map-coords {
  position: absolute;
  bottom: 12px; right: 12px;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  background: rgba(15,20,9,0.7);
  padding: 4px 8px;
  border-radius: 4px;
}

/* ─── INSIGHT PANEL ─── */
.insight-panel {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.insight-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
}
.insight-card-title {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 1px;
  margin-bottom: 10px;
}
.kpi-big {
  font-family: var(--display);
  font-size: 36px;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
  margin-bottom: 4px;
}
.kpi-sub { font-size: 12px; color: var(--text2); }
.kpi-change {
  display: inline-flex; align-items: center; gap: 4px;
  font-family: var(--mono);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 20px;
  margin-top: 6px;
}
.kpi-change.up   { background: rgba(111,174,60,0.15); color: var(--leaf2); }
.kpi-change.down { background: rgba(239,68,68,0.15);  color: var(--red); }
.kpi-change.warn { background: rgba(245,158,11,0.15); color: var(--amber); }

/* ─── ZONE BARS ─── */
.zone-bar { margin: 6px 0; }
.zone-bar-label {
  display: flex; justify-content: space-between;
  font-size: 11px; margin-bottom: 3px;
}
.zone-bar-label span:first-child { color: var(--text2); }
.zone-bar-label span:last-child { font-family: var(--mono); color: var(--text); }
.zone-track {
  height: 6px;
  background: var(--bg3);
  border-radius: 3px;
  overflow: hidden;
}
.zone-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 1s ease;
}

/* ─── ACTION BUTTONS ─── */
.action-btn {
  width: 100%;
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  border: none;
}
.action-btn.primary {
  background: var(--leaf);
  color: var(--bg);
}
.action-btn.primary:hover { background: var(--leaf2); }
.action-btn.secondary {
  background: var(--bg3);
  color: var(--text2);
  border: 1px solid var(--border2);
}
.action-btn.secondary:hover { color: var(--text); border-color: var(--leaf-dim); }

/* ─── ALERT BOX ─── */
.alert-box {
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 12px;
  line-height: 1.5;
  border: 1px solid;
}
.alert-box.red   { background: rgba(239,68,68,0.08);  border-color: rgba(239,68,68,0.3);  color: #FCA5A5; }
.alert-box.amber { background: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.3); color: #FCD34D; }
.alert-box.green { background: rgba(111,174,60,0.08); border-color: rgba(111,174,60,0.3); color: var(--leaf2); }
.alert-box.blue  { background: rgba(74,158,255,0.08); border-color: rgba(74,158,255,0.3); color: #93C5FD; }
.alert-title { font-weight: 600; margin-bottom: 3px; font-size: 12px; }

/* ─── DIVIDER ─── */
.divider { height: 1px; background: var(--border); margin: 12px 0; }

/* ─── WEATHER BAR ─── */
.weather-bar {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: 16px;
  flex-wrap: wrap;
}
.weather-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px; color: var(--text2);
}
.weather-value { font-family: var(--mono); color: var(--text); font-size: 12px; }
.weather-label { font-size: 10px; color: var(--text3); }

/* ─── TIMELINE SLIDER ─── */
.timeline-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 16px;
  margin-top: 16px;
}
.timeline-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 10px;
}
.timeline-title { font-family: var(--mono); font-size: 10px; color: var(--text3); letter-spacing: 0.5px; }
.timeline-date { font-family: var(--mono); font-size: 11px; color: var(--leaf2); }
input[type=range] {
  width: 100%;
  accent-color: var(--leaf);
  height: 4px;
}

/* ─── STAT GRID ─── */
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.stat-box {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
}
.stat-val {
  font-family: var(--display);
  font-size: 20px;
  font-weight: 600;
  color: var(--text);
  line-height: 1;
}
.stat-key { font-size: 10px; color: var(--text3); font-family: var(--mono); margin-top: 4px; }

/* ─── TABLE ─── */
.mini-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.mini-table th {
  text-align: left;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 0.5px;
  padding: 6px 0 8px;
  border-bottom: 1px solid var(--border);
}
.mini-table td {
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  color: var(--text2);
}
.mini-table td:last-child { text-align: right; font-family: var(--mono); color: var(--text); }
.mini-table tr:last-child td { border-bottom: none; }

/* ─── COUNTDOWN ─── */
.countdown-block {
  background: linear-gradient(135deg, rgba(111,174,60,0.15) 0%, rgba(111,174,60,0.03) 100%);
  border: 1px solid var(--leaf-dim);
  border-radius: 10px;
  padding: 16px;
  text-align: center;
}
.countdown-num {
  font-family: var(--display);
  font-size: 52px;
  font-weight: 700;
  color: var(--leaf2);
  line-height: 1;
}
.countdown-unit { font-size: 12px; color: var(--text2); margin-top: 2px; }
.countdown-date { font-family: var(--mono); font-size: 13px; color: var(--text); margin-top: 8px; }

/* ─── EARNINGS ─── */
.earnings-block {
  background: linear-gradient(135deg, rgba(212,175,55,0.15) 0%, rgba(212,175,55,0.03) 100%);
  border: 1px solid rgba(212,175,55,0.3);
  border-radius: 10px;
  padding: 16px;
  text-align: center;
}
.earnings-num {
  font-family: var(--display);
  font-size: 32px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
}
.earnings-sub { font-size: 11px; color: var(--text2); margin-top: 4px; }
.tier-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  background: rgba(212,175,55,0.15);
  border: 1px solid rgba(212,175,55,0.3);
  color: var(--gold);
  font-size: 10px;
  font-family: var(--mono);
  font-weight: 500;
  margin-top: 8px;
}

/* ─── INSURANCE STATUS ─── */
.insurance-status {
  border-radius: 10px;
  padding: 16px;
  text-align: center;
  border: 1px solid;
}
.insurance-status.safe {
  background: rgba(111,174,60,0.08);
  border-color: rgba(111,174,60,0.3);
}
.insurance-status.triggered {
  background: rgba(239,68,68,0.08);
  border-color: rgba(239,68,68,0.4);
}
.status-icon { font-size: 28px; margin-bottom: 6px; }
.status-text { font-size: 15px; font-weight: 600; color: var(--text); }
.status-sub { font-size: 11px; color: var(--text2); margin-top: 2px; }

/* ─── PROGRESS RING ─── */
.health-ring {
  display: flex; flex-direction: column; align-items: center;
  gap: 4px;
}
.ring-svg { transform: rotate(-90deg); }

/* ─── DASHBOARD ─── */
.dashboard-hero {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 20px;
  position: relative;
  overflow: hidden;
}
.hero-bg-pattern {
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: 200px;
  background: linear-gradient(135deg, transparent, rgba(111,174,60,0.05));
  pointer-events: none;
}
.hero-title {
  font-family: var(--display);
  font-size: 26px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.5px;
  margin-bottom: 4px;
}
.hero-subtitle { font-size: 13px; color: var(--text2); margin-bottom: 16px; }
.hero-stats { display: flex; gap: 24px; flex-wrap: wrap; }
.hero-stat {}
.hero-stat-val {
  font-family: var(--display);
  font-size: 22px;
  font-weight: 600;
  color: var(--leaf2);
  line-height: 1;
}
.hero-stat-key { font-size: 10px; color: var(--text3); font-family: var(--mono); margin-top: 2px; }

.module-gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
  margin-bottom: 20px;
}
.gallery-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.gallery-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--leaf);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.2s;
}
.gallery-card:hover::before { transform: scaleX(1); }
.gallery-card:hover { border-color: var(--border2); background: #273319; }
.gallery-card-icon { font-size: 22px; margin-bottom: 8px; }
.gallery-card-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 3px;
}
.gallery-card-desc { font-size: 11px; color: var(--text2); line-height: 1.4; }
.gallery-card-status {
  display: flex; align-items: center; gap: 5px;
  margin-top: 10px;
  font-size: 10px;
  font-family: var(--mono);
}

/* ─── ONBOARDING ─── */
.onboarding-wrap {
  max-width: 600px;
  margin: 40px auto;
  padding: 0 24px;
}
.onboard-step-indicator {
  display: flex; gap: 6px; margin-bottom: 28px;
}
.step-dot {
  height: 3px;
  border-radius: 2px;
  transition: all 0.3s;
}
.step-dot.active { background: var(--leaf); flex: 2; }
.step-dot.done   { background: var(--leaf-dim); flex: 1; }
.step-dot.todo   { background: var(--border2); flex: 1; }
.onboard-title {
  font-family: var(--display);
  font-size: 28px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.5px;
  margin-bottom: 6px;
}
.onboard-sub { font-size: 14px; color: var(--text2); margin-bottom: 24px; line-height: 1.5; }
.fake-map-onboard {
  width: 100%;
  height: 260px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  margin-bottom: 16px;
}
.input-field {
  width: 100%;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 8px;
